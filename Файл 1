# --- База данных (SQLite) ---
def init_db():
    conn = sqlite3.connect('users.db')
    cur = conn.cursor()
    cur.execute('''
        CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY,
            age INTEGER,
            weight REAL,
            height REAL,
            activity TEXT,
            goal TEXT
        )
    ''')
    conn.commit()
    conn.close()

init_db()

# --- Функция расчета КБЖУ ---
def calculate_kbju(weight, height, age, activity, goal):
    # Упрощенная формула (Миффлин-Сан Жеор для мужчин, для примера)
    bmr = (10 * weight) + (6.25 * height) - (5 * age) + 5

    activity_coeff = {
        'low': 1.2,
        'medium': 1.55,
        'high': 1.725
    }.get(activity, 1.2)

    tdee = bmr * activity_coeff

    goal_coeff = {
        'weight_loss': 0.85,
        'maintenance': 1.0,
        'muscle_gain': 1.1
    }.get(goal, 1.0)

    calories = round(tdee * goal_coeff)
    protein = round((calories * 0.3) / 4)
    fat = round((calories * 0.25) / 9)
    carbs = round((calories * 0.45) / 4)

    return calories, protein, fat, carbs

