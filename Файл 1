# --- База данных (SQLite) ---
def init_db():
    conn = sqlite3.connect('users.db')
    cur = conn.cursor()
    cur.execute('''
        CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY,
            age INTEGER,
            weight REAL,
            height REAL,
            activity TEXT,
            goal TEXT
        )
    ''')
    # Таблица для истории рецептов
    cur.execute('''
        CREATE TABLE IF NOT EXISTS recipe_history (
            user_id INTEGER,
            recipe_name TEXT,
            date TEXT,
            FOREIGN KEY (user_id) REFERENCES users(user_id)
        )
    ''')
    conn.commit()
    conn.close()
    print("✅ База данных инициализирована")

init_db()

# --- Функция расчета КБЖУ ---
def calculate_kbju(weight, height, age, activity, goal):
    # Формула Миффлина-Сан Жеора
    bmr = (10 * weight) + (6.25 * height) - (5 * age) + 5

    activity_coeff = {
        'low': 1.2,
        'medium': 1.55,
        'high': 1.725
    }.get(activity, 1.2)

    tdee = bmr * activity_coeff

    goal_coeff = {
        'weight_loss': 0.85,
        'maintenance': 1.0,
        'muscle_gain': 1.1
    }.get(goal, 1.0)

    calories = round(tdee * goal_coeff)
    protein = round((calories * 0.3) / 4)
    fat = round((calories * 0.25) / 9)
    carbs = round((calories * 0.45) / 4)

    return calories, protein, fat, carbs

# --- Функция для получения последних рецептов пользователя ---
def get_recent_recipes(user_id, limit=5):
    conn = sqlite3.connect('users.db')
    cur = conn.cursor()
    cur.execute('''
        SELECT recipe_name FROM recipe_history 
        WHERE user_id = ? 
        ORDER BY date DESC LIMIT ?
    ''', (user_id, limit))
    recipes = cur.fetchall()
    conn.close()
    return [r[0] for r in recipes]

# --- Функция сохранения рецепта в историю ---
def save_recipe_to_history(user_id, recipe_name):
    conn = sqlite3.connect('users.db')
    cur = conn.cursor()
    cur.execute('''
        INSERT INTO recipe_history (user_id, recipe_name, date)
        VALUES (?, ?, ?)
    ''', (user_id, recipe_name[:100], datetime.now().isoformat()))
    conn.commit()
    conn.close()

# --- Функция генерации рецепта через DeepSeek API ---
def generate_deepseek_recipe(user_params, user_id):
    """
    Генерирует рецепт с помощью DeepSeek API
    """
    age, weight, height, activity, goal = user_params
    calories, protein, fat, carbs = calculate_kbju(weight, height, age, activity, goal)
    
    # Определяем цель на русском
    goal_text = {
        'weight_loss': 'похудение',
        'maintenance': 'поддержание веса',
        'muscle_gain': 'набор мышечной массы'
    }.get(goal, 'здоровое питание')
    
    # Получаем последние рецепты пользователя, чтобы не повторяться
    recent_recipes = get_recent_recipes(user_id)
    recent_recipes_text = ", ".join(recent_recipes) if recent_recipes else "нет истории"
    
    # Создаем системный промпт для DeepSeek
    system_prompt = """Ты - профессиональный спортивный диетолог и шеф-повар с 15-летним стажем. 
    Твоя задача - составлять уникальные, вкусные и полезные рецепты с точным расчетом КБЖУ.
    Отвечай только на русском языке, используй понятные ингредиенты, которые можно купить в обычном магазине.
    Всегда указывай точные граммовки и пошаговые инструкции."""
    
    # Промпт для пользователя
    user_prompt = f"""Составь рецепт одного приема пищи (завтрак, обед или ужин - выбери случайно) для спортсмена.

    Параметры пользователя:
    - Цель: {goal_text}
    - Дневная норма калорий: {calories} ккал
    - Белки: {protein} г, Жиры: {fat} г, Углеводы: {carbs} г
    
    Последние рецепты пользователя (НЕ повторяй их!): {recent_recipes_text}
    
    Требования к рецепту:
    1. Блюдо должно быть РАЗНЫМ и НЕ ПОВТОРЯТЬ предыдущие рецепты
    2. Укажи точные граммовки для каждого ингредиента
    3. Рассчитай КБЖУ для этого конкретного блюда (примерно 1/3 от дневной нормы: {round(calories/3)}-{round(calories/2)} ккал)
    4. Напиши подробную инструкцию приготовления (4-6 шагов)
    5. Добавь 1-2 совета по подаче или замене ингредиентов
    
    Формат ответа (строго соблюдай этот формат):
    🍽 НАЗВАНИЕ: [название блюда]
    
    🥗 ИНГРЕДИЕНТЫ:
    • [ингредиент 1] — [количество] г/шт
    • [ингредиент 2] — [количество] г/шт
    ...
    
    📝 ПРИГОТОВЛЕНИЕ:
    1. [шаг 1]
    2. [шаг 2]
    ...
    
    📊 КБЖУ БЛЮДА:
    • Калории: ... ккал
    • Белки: ... г
    • Жиры: ... г
    • Углеводы: ... г
    
    💡 СОВЕТ: [совет по подаче или замене]
    """
    
    # Проверяем, есть ли ключ DeepSeek
    if not DEEPSEEK_API_KEY:
        print("⚠️ DeepSeek API ключ не найден! Использую запасные рецепты.")
        return get_fallback_recipe()
    
    # Подготовка данных для DeepSeek API
    payload = {
        "model": "deepseek-chat",
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt}
        ],
        "temperature": 0.9,
        "max_tokens": 1500,
        "top_p": 0.95,
        "frequency_penalty": 0.3,
        "presence_penalty": 0.3,
        "stream": False
    }
    
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {DEEPSEEK_API_KEY}"
    }
    
    try:
        print(f"📡 Отправляю запрос к DeepSeek API для пользователя {user_id}")
        response = requests.post(
            DEEPSEEK_API_URL,
            headers=headers,
            json=payload,
            timeout=30
        )
        
        if response.status_code == 200:
            result = response.json()
            recipe_text = result['choices'][0]['message']['content']
            print(f"✅ Получен ответ от DeepSeek для пользователя {user_id}")
            
            # Пытаемся извлечь название рецепта для истории
            try:
                for line in recipe_text.split('\n'):
                    if 'НАЗВАНИЕ:' in line or '🍽' in line:
                        recipe_name = line.replace('🍽', '').replace('НАЗВАНИЕ:', '').strip()
                        save_recipe_to_history(user_id, recipe_name)
                        print(f"📝 Сохранен рецепт в историю: {recipe_name}")
                        break
            except Exception as e:
                print(f"⚠️ Не удалось сохранить историю: {e}")
            
            return recipe_text
        else:
            print(f"❌ DeepSeek API error: {response.status_code} - {response.text}")
            return get_fallback_recipe()
            
    except Exception as e:
        print(f"❌ Exception in DeepSeek API call: {e}")
        return get_fallback_recipe()

