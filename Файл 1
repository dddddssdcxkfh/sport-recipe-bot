# --- Команды бота ---
@bot.message_handler(commands=['start'])
def start(message):
    markup = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)
    markup.add('📝 Заполнить анкету', '🍽 Рецепт на сегодня', '📊 Моя норма')
    bot.send_message(message.chat.id, "Привет! Я помогу тебе с питанием для спорта. Начнем с анкеты? Нажми кнопку ниже.", reply_markup=markup)

@bot.message_handler(func=lambda message: message.text == '📝 Заполнить анкету')
def ask_age(message):
    msg = bot.send_message(message.chat.id, "Сколько тебе лет?")
    bot.register_next_step_handler(msg, ask_weight)

def ask_weight(message):
    if not message.text.isdigit():
        msg = bot.send_message(message.chat.id, "Пожалуйста, введи число (возраст).")
        bot.register_next_step_handler(msg, ask_weight)
        return
    user_data = {'age': int(message.text)}
    bot.register_next_step_handler(bot.send_message(message.chat.id, "Твой вес (в кг)?"), ask_height, user_data)

def ask_height(message, user_data):
    try:
        user_data['weight'] = float(message.text.replace(',', '.'))
        bot.register_next_step_handler(bot.send_message(message.chat.id, "Твой рост (в см)?"), ask_activity, user_data)
    except:
        msg = bot.send_message(message.chat.id, "Введи вес числом (например 75.5).")
        bot.register_next_step_handler(msg, ask_height, user_data)

def ask_activity(message, user_data):
    try:
        user_data['height'] = float(message.text.replace(',', '.'))
        markup = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True, one_time_keyboard=True)
        markup.add('Низкая (офис)', 'Средняя (тренировки 3 раза)', 'Высокая (спортсмен)')
        msg = bot.send_message(message.chat.id, "Твой уровень активности?", reply_markup=markup)
        bot.register_next_step_handler(msg, ask_goal, user_data)
    except:
        msg = bot.send_message(message.chat.id, "Введи рост числом (например 175).")
        bot.register_next_step_handler(msg, ask_activity, user_data)

def ask_goal(message, user_data):
    activity_map = {'Низкая (офис)': 'low', 'Средняя (тренировки 3 раза)': 'medium', 'Высокая (спортсмен)': 'high'}
    user_data['activity'] = activity_map.get(message.text, 'medium')
    markup = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True, one_time_keyboard=True)
    markup.add('Похудение', 'Поддержание формы', 'Набор массы')
    msg = bot.send_message(message.chat.id, "Твоя цель?", reply_markup=markup)
    bot.register_next_step_handler(msg, save_profile, user_data)

def save_profile(message, user_data):
    goal_map = {'Похудение': 'weight_loss', 'Поддержание формы': 'maintenance', 'Набор массы': 'muscle_gain'}
    user_data['goal'] = goal_map.get(message.text, 'maintenance')

    # Сохраняем в БД
    conn = sqlite3.connect('users.db')
    cur = conn.cursor()
    cur.execute('INSERT OR REPLACE INTO users (user_id, age, weight, height, activity, goal) VALUES (?, ?, ?, ?, ?, ?)',
                (message.chat.id, user_data['age'], user_data['weight'], user_data['height'], user_data['activity'], user_data['goal']))
    conn.commit()
    conn.close()

    bot.send_message(message.chat.id, "✅ Анкета сохранена! Теперь я знаю твои параметры.")

@bot.message_handler(func=lambda message: message.text == '📊 Моя норма')
def show_norm(message):
    conn = sqlite3.connect('users.db')
    cur = conn.cursor()
    cur.execute('SELECT age, weight, height, activity, goal FROM users WHERE user_id = ?', (message.chat.id,))
    data = cur.fetchone()
    conn.close()

    if data:
        age, weight, height, activity, goal = data
        calories, protein, fat, carbs = calculate_kbju(weight, height, age, activity, goal)
        bot.send_message(message.chat.id, f"📊 *Твоя дневная норма:*\n🔥 Калории: {calories} ккал\n🥩 Белки: {protein} г\n🥑 Жиры: {fat} г\n🍚 Углеводы: {carbs} г", parse_mode='Markdown')
    else:
        bot.send_message(message.chat.id, "Сначала заполни анкету, нажми '📝 Заполнить анкету'.")

